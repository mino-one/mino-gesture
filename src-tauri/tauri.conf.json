{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mino-gesture",
  "version": "0.1.0",
  "identifier": "com.mino.gesture",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "mino-gesture",
        "width": 840,
        "height": 620,
        "resizable": true
      },
      {
        "label": "overlay",
        "title": "",
        "url": "/overlay.html",
        "width": 1920,
        "height": 1200,
        "x": 0,
        "y": 0,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "resizable": false,
        "acceptFirstMouse": true,
        "contentProtected": false,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/logo.png"]
  }
}
