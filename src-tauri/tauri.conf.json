{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mino Gesture",
  "version": "0.1.5",
  "identifier": "com.mino.gesture",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "backgroundColor": "#fff",
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "width": 1180,
        "height": 820,
        "minWidth": 880,
        "minHeight": 720,
        "resizable": true
      },
      {
        "label": "overlay",
        "title": "",
        "url": "/overlay.html",
        "width": 1920,
        "height": 1200,
        "x": 0,
        "y": 0,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "resizable": false,
        "acceptFirstMouse": true,
        "contentProtected": false,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  }
}
