{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mino Gesture",
  "version": "0.1.0",
  "identifier": "com.mino.gesture",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "backgroundColor": "#EEF1F7",
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "width": 720,
        "minWidth": 720,
        "maxWidth": 720,
        "height": 720,
        "resizable": false
      },
      {
        "label": "overlay",
        "title": "",
        "url": "/overlay.html",
        "width": 1920,
        "height": 1200,
        "x": 0,
        "y": 0,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "resizable": false,
        "acceptFirstMouse": true,
        "contentProtected": false,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/logo.png"]
  }
}
